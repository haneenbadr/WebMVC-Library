@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-5">
    <div class="row text-center mb-5">
        <div class="col-md-4">
            <a href="/Book/Index" class="card p-4 shadow-sm text-decoration-none text-dark border-primary">
                <div class="h3">Books</div>
            </a>
        </div>
        <div class="col-md-4">
            <div class="card p-4 shadow-sm border-secondary text-muted">
                <div class="h3">Categories</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-4 shadow-sm border-secondary text-muted">
                <div class="h3">Authors</div>
            </div>
        </div>
    </div>

    <div class="row align-items-center bg-light p-5 rounded shadow-sm">
        <div class="col-md-6">
            <h1 class="display-4 fw-bold">Library Management</h1>
            <p class="lead text-muted">
                Simple Admin Dashboard for managing your library inventory.
                Track books, organize categories, and manage authors all in one place.
            </p>
        </div>
        <div class="col-md-6 text-center">

            <img src="/images/library.jpg" class="img-fluid rounded shadow" alt="Library Image">
        </div>
    </div>
</div>