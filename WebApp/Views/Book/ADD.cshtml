@model EntityFramework2.Entities.Book

<div class="container mt-5">
    <div class="card shadow-sm p-4 mx-auto" style="max-width: 600px; border-top: 5px solid #0d6efd;">
        <h2 class="mb-1">Add New Book</h2>
        <p class="text-muted mb-4">Fill in the details to add a new book to the library.</p>

        <form asp-action="Add" method="post">

            <div class="mb-3">
                <label class="fw-bold small text-muted">TITLE</label>
                <input asp-for="Title" class="form-control" placeholder="Enter book title" required />
            </div>

            <div class="mb-3">
                <label class="fw-bold small text-muted">ISBN</label>
                <input asp-for="ISBN" class="form-control" type="number" placeholder="Enter ISBN number" required />
            </div>

            <div class="mb-3">
                <label class="fw-bold small text-muted">AUTHOR ID</label>
                <input asp-for="AuthorID" class="form-control" type="number" placeholder="Enter an existing Author ID" required />
                <span class="text-info small">Make sure this ID exists in the Authors table.</span>
            </div>

            <div class="mb-3">
                <label class="fw-bold small text-muted">CATEGORY</label>
                <select asp-for="CategoryID" asp-items="ViewBag.CategoryList" class="form-select" required>
                    <option value="">-- Select Category --</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="fw-bold small text-muted">PUBLISH YEAR</label>
                <input asp-for="PublishYear" class="form-control" type="date" required />
            </div>

            <div class="mb-3">
                <label class="fw-bold small text-muted">PRICE</label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" />
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary px-5">Save Book</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>