@model IEnumerable<EntityFramework2.Entities.Book>

<div class="container mt-4">
    @* التاريخ اللي شلناه في الـ TempData *@
    <p class="text-muted small">@ViewBag.Date</p>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Books</h2>
        @* تعديل زرار الإضافة ليذهب للأكشن Add *@
        <a asp-action="Add" class="btn btn-primary">+ Add Book</a>
    </div>

    <div class="mb-3">
        
        <select asp-items="ViewBag.CategoryList" class="form-select w-25">
            <option value="">All Categories</option>
        </select>
    </div>

    <table class="table table-hover border">
        <thead class="table-light">
            <tr>
                <th>TITLE</th>
                <th>AUTHOR</th>
                <th>ISBN</th>
                <th>ACTIONS</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in Model)
            {
                <tr>
                    <td>@book.Title</td>
                    <td>@book.Author?.Name</td>
                    <td>@book.ISBN</td>
                    <td>
                         
                        <a asp-action="Details" asp-route-id="@book.BookID" class="btn btn-sm btn-outline-dark">Details</a>

                        <a asp-action="Edit" asp-route-id="@book.BookID" class="btn btn-sm btn-warning text-white">Edit</a>

                        <a asp-action="Delete" asp-route-id="@book.BookID"
                           class="btn btn-sm btn-danger"
                           onclick="return confirm('Are you sure you want to delete this book?')">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>